"aiprompts.prompt.bottleneck.desc" = "Détecte les goulots d'étranglement des performances, les points lents et les charges de travail inutiles sur l'ensemble de la base de code.";
"aiprompts.prompt.swiftuiRender.title" = "Optimisation du Rendu SwiftUI";
"aiprompts.prompt.swiftuiRender.desc" = "Détecte les re-rendus inutiles, les erreurs de gestion d'état et les problèmes de performances de l'interface utilisateur dans la hiérarchie des vues SwiftUI.";
"aiprompts.prompt.appLaunch.title" = "Optimisation du Démarrage & du Lancement de l'App";
"aiprompts.prompt.appLaunch.desc" = "Analyse le temps de démarrage de l'app, les performances de lancement à froid/à chaud et la vitesse d'affichage du premier écran.";

"aiprompts.prompt.architectureDeep.title" = "Revue Approfondie de l'Architecture";
"aiprompts.prompt.architectureDeep.desc" = "Évalue en profondeur l'architecture du projet en termes de principes SOLID, de gestion des dépendances et de modularité.";
"aiprompts.prompt.designPatterns.title" = "Modèles de Conception & Bonnes Pratiques";
"aiprompts.prompt.designPatterns.desc" = "Analyse l'utilisation actuelle des modèles de conception, suggère les modèles manquants et détecte les anti-patrons.";
"aiprompts.prompt.refactoringGuide.title" = "Guide de Refactoring";
"aiprompts.prompt.refactoringGuide.desc" = "Marque les blocs de code nécessitant un refactoring selon le catalogue de refactoring de Martin Fowler et fournit un guide étape par étape.";

"aiprompts.prompt.testCoverage.title" = "Couverture des Tests & Analyse des Écarts";
"aiprompts.prompt.testCoverage.desc" = "Analyse de manière exhaustive les écarts de couverture des tests, les scénarios de test manquants et les chemins de code non testés critiques.";
"aiprompts.prompt.unitTestAudit.title" = "Audit de Qualité des Tests Unitaires";
"aiprompts.prompt.unitTestAudit.desc" = "Audite la qualité, la fiabilité et la maintenabilité des tests unitaires existants.";
"aiprompts.prompt.testGenerator.title" = "Assistant de Rédaction de Tests";
"aiprompts.prompt.testGenerator.desc" = "Génère des tests unitaires complets et fonctionnels pour le fichier de code fourni.";

"aiprompts.prompt.apiDocs.title" = "Documentation Automatisée de l'API";
