"aiprompts.prompt.networkAudit.title" = "Audit de la Couche Réseau";
"aiprompts.prompt.networkAudit.desc" = "Audite de manière exhaustive la couche réseau, les appels d'API, la gestion des erreurs et le flux de données.";
