"aiprompts.prompt.unusedCode.desc" = "프로젝트에서 사용되지 않는 함수, 변수, 클래스 및 가져오기를 감지합니다.";
"aiprompts.prompt.codeSmells.title" = "코드 악취 및 안티 패턴";
"aiprompts.prompt.codeSmells.desc" = "코드 악취, 안티 패턴 및 잠재적 버그를 깊이 있게 감지합니다.";
"aiprompts.prompt.memoryLeaks.title" = "메모리 누수 및 유지 사이클";
"aiprompts.prompt.memoryLeaks.desc" = "Swift/Apple 프로젝트의 메모리 누수, 유지 사이클 및 리소스 관리 오류를 포괄적으로 분석합니다.";
"aiprompts.prompt.securityAudit.title" = "보안 감사";
"aiprompts.prompt.securityAudit.desc" = "보안 취약점, 위험한 코드 패턴 및 데이터 보호 결함을 포괄적으로 감사합니다.";
"aiprompts.prompt.errorHandling.title" = "오류 처리 감사";
"aiprompts.prompt.errorHandling.desc" = "오류 처리 결함, 강제 언래핑 및 크래시 위험을 감지합니다.";

"aiprompts.prompt.bottleneck.title" = "성능 병목 현상 분석";
"aiprompts.prompt.bottleneck.desc" = "전체 코드베이스의 성능 병목 현상, 느린 지점 및 불필요한 워크로드를 감지합니다.";
"aiprompts.prompt.swiftuiRender.title" = "SwiftUI 렌더링 최적화";
"aiprompts.prompt.swiftuiRender.desc" = "SwiftUI 뷰 계층 구조의 불필요한 재렌더링, 상태 관리 오류 및 UI 성능 문제를 감지합니다.";
"aiprompts.prompt.appLaunch.title" = "앱 시작 및 실행 최적화";
"aiprompts.prompt.appLaunch.desc" = "앱 시작 시간, 콜드/웜 실행 성능 및 첫 화면 표시 속도를 분석합니다.";

"aiprompts.prompt.architectureDeep.title" = "아키텍처 정밀 점검";
"aiprompts.prompt.architectureDeep.desc" = "SOLID 원칙, 종속성 관리 및 모듈성 측면에서 프로젝트의 아키텍처를 깊이 있게 평가합니다.";
"aiprompts.prompt.designPatterns.title" = "디자인 패턴 및 모범 사례";
"aiprompts.prompt.designPatterns.desc" = "현재 디자인 패턴 사용을 분석하고 부족한 패턴을 제안하며 안티 패턴을 감지합니다.";
"aiprompts.prompt.refactoringGuide.title" = "리팩토링 가이드";
"aiprompts.prompt.refactoringGuide.desc" = "마틴 파울러의 리팩토링 카탈로그에 따라 리팩토링이 필요한 코드 블록을 표시하고 단계별 가이드를 제공합니다.";

"aiprompts.prompt.testCoverage.title" = "테스트 커버리지 및 갭 분석";
"aiprompts.prompt.testCoverage.desc" = "테스트 커버리지 갭, 누락된 테스트 시나리오 및 테스트되지 않은 중요한 코드 경로를 포괄적으로 분석합니다.";
"aiprompts.prompt.unitTestAudit.title" = "단위 테스트 품질 감사";
"aiprompts.prompt.unitTestAudit.desc" = "기존 단위 테스트의 품질, 안정성 및 유지 관리 가능성을 감사합니다.";
"aiprompts.prompt.testGenerator.title" = "테스트 작성 어시스턴트";
"aiprompts.prompt.testGenerator.desc" = "제공된 코드 파일에 대해 포괄적이고 작동하는 단위 테스트를 생성합니다.";

"aiprompts.prompt.apiDocs.title" = "자동화된 API 설명서";
"aiprompts.prompt.apiDocs.desc" = "모든 공용 API에 대한 자세한 설명서를 Swift DocC 형식으로 생성합니다.";
"aiprompts.prompt.readmeDocs.title" = "README 및 프로젝트 설명서";
"aiprompts.prompt.readmeDocs.desc" = "전문적이고 포괄적인 README 및 프로젝트 설명서를 생성합니다.";
"aiprompts.prompt.commentsAudit.title" = "코드 주석 분석";
"aiprompts.prompt.commentsAudit.desc" = "기존 주석을 분석하여 오래되거나 잘못된 주석을 감지하고 개선 제안을 제공합니다.";

"aiprompts.prompt.crashBugAudit.title" = "크래시 및 버그 분석";
"aiprompts.prompt.crashBugAudit.desc" = "크래시 로그 및 버그 보고서를 분석하여 근본 원인을 찾고 수정 사항을 제안합니다.";
"aiprompts.prompt.instrumentsGuide.title" = "Instruments 및 프로파일링 가이드";
"aiprompts.prompt.instrumentsGuide.desc" = "Xcode Instruments를 사용한 프로파일링 가이드와 프로젝트별 권장 사항을 제공합니다.";

"aiprompts.prompt.networkAudit.title" = "네트워크 계층 감사";
"aiprompts.prompt.networkAudit.desc" = "네트워킹 계층, API 호출, 오류 처리 및 데이터 흐름을 포괄적으로 감사합니다.";
"aiprompts.prompt.apiMock.title" = "API 모의 및 테스트 인프라";
"aiprompts.prompt.apiMock.desc" = "API 테스트 인프라, 모의 서버 구성 및 네트워크 테스트 전략을 생성합니다.";

"aiprompts.prompt.a11yAudit.title" = "접근성 감사";
"aiprompts.prompt.a11yAudit.desc" = "접근성 표준 준수 여부를 감사하고 VoiceOver, 다이내믹 타입 및 색상 대비 문제를 감지합니다.";

"aiprompts.prompt.i18nAudit.title" = "다국어 지원 종합 감사";
"aiprompts.prompt.i18nAudit.desc" = "하드코딩된 문자열, 누락된 번역, 날짜/숫자 형식 및 RTL 지원을 포괄적으로 감사합니다.";

"aiprompts.prompt.gitWorkflow.title" = "Git 워크플로우 최적화";
"aiprompts.prompt.gitWorkflow.desc" = "Git 기록, 브랜치 전략, 커밋 품질 및 .gitignore 구성을 감사합니다.";
"aiprompts.prompt.cicdPipeline.title" = "CI/CD 파이프라인 설계";
"aiprompts.prompt.cicdPipeline.desc" = "프로젝트 유형에 적합한 CI/CD 파이프라인 설계, 빌드 최적화 및 배포 전략을 생성합니다.";

"aiprompts.prompt.depAudit.title" = "종속성 감사";
"aiprompts.prompt.depAudit.desc" = "보안, 최신 상태, 라이선스 준수 및 필요성에 대해 모든 종속성을 감사합니다.";

"aiprompts.prompt.crudGen.title" = "CRUD 기능 생성기";
"aiprompts.prompt.crudGen.desc" = "새 엔티티에 대한 완벽한 CRUD 기능(Model, Service, ViewModel, View)을 생성합니다.";
"aiprompts.prompt.boilerplateGen.title" = "프로젝트 보일러플레이트 생성기";
"aiprompts.prompt.boilerplateGen.desc" = "새 모듈 또는 기능에 필요한 모든 파일 및 폴더 구조를 생성합니다.";
"aiprompts.prompt.projectReport.title" = "프로젝트 분석 보고서";
"aiprompts.prompt.projectReport.desc" = "프로젝트의 전체적인 엑스레이(아키텍처, 품질, 위험 및 개선 제안)를 제공합니다.";


