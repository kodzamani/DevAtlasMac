"aiprompts.prompt.memoryLeaks.desc" = "Analizza in modo completo perdite di memoria, retain cycle ed errori di gestione delle risorse nei progetti Swift/Apple.";
"aiprompts.prompt.securityAudit.title" = "Audit di Sicurezza";
"aiprompts.prompt.securityAudit.desc" = "Verifica in modo completo vulnerabilità di sicurezza, pattern di codice pericolosi e carenze nella protezione dei dati.";
"aiprompts.prompt.errorHandling.title" = "Audit della Gestione degli Errori";
"aiprompts.prompt.errorHandling.desc" = "Rileva carenze nella gestione degli errori, force unwrap e rischi di crash.";

"aiprompts.prompt.bottleneck.title" = "Analisi dei Colli di Bottiglia nelle Prestazioni";
"aiprompts.prompt.bottleneck.desc" = "Rileva colli di bottiglia nelle prestazioni, punti lenti e carichi di lavoro non necessari nell'intera base di codice.";
"aiprompts.prompt.swiftuiRender.title" = "Ottimizzazione del Rendering di SwiftUI";
"aiprompts.prompt.swiftuiRender.desc" = "Rileva re-rendering non necessari, errori di gestione dello stato e problemi di prestazioni dell'interfaccia utente nella gerarchia delle viste SwiftUI.";
"aiprompts.prompt.appLaunch.title" = "Ottimizzazione del Lancio & Avvio dell'App";
"aiprompts.prompt.appLaunch.desc" = "Analizza il tempo di avvio dell'app, le prestazioni di lancio a freddo/caldo e la velocità di visualizzazione della prima schermata.";

"aiprompts.prompt.architectureDeep.title" = "Revisione Approfondita dell'Architettura";
"aiprompts.prompt.architectureDeep.desc" = "Valuta profondamente l'architettura del progetto in termini di principi SOLID, gestione delle dipendenze e modularità.";
"aiprompts.prompt.designPatterns.title" = "Design Pattern & Best Practice";
"aiprompts.prompt.designPatterns.desc" = "Analizza l'uso attuale dei design pattern, suggerisce pattern mancanti e rileva anti-pattern.";
"aiprompts.prompt.refactoringGuide.title" = "Guida al Refactoring";
"aiprompts.prompt.refactoringGuide.desc" = "Contrassegna i blocchi di codice che richiedono il refactoring in base al catalogo di refactoring di Martin Fowler e fornisce una guida passo-passo.";

"aiprompts.prompt.testCoverage.title" = "Copertura dei Test & Analisi dei Gap";
"aiprompts.prompt.testCoverage.desc" = "Analizza in modo completo i gap nella copertura dei test, gli scenari di test mancanti e i percorsi di codice critici non testati.";
"aiprompts.prompt.unitTestAudit.title" = "Audit di Qualità dei Test Unitari";
"aiprompts.prompt.unitTestAudit.desc" = "Verifica la qualità, l'affidabilità e la manutenibilità degli unit test esistenti.";
"aiprompts.prompt.testGenerator.title" = "Assistente alla Scrittura di Test";
"aiprompts.prompt.testGenerator.desc" = "Genera unit test completi e funzionanti per il file di codice fornito.";

"aiprompts.prompt.apiDocs.title" = "Documentazione API Automatizzata";
"aiprompts.prompt.apiDocs.desc" = "Genera documentazione dettagliata per tutte le API pubbliche nel formato Swift DocC.";
"aiprompts.prompt.readmeDocs.title" = "README & Documentazione del Progetto";
"aiprompts.prompt.readmeDocs.desc" = "Crea un README professionale e completo e la documentazione del progetto.";
"aiprompts.prompt.commentsAudit.title" = "Analisi dei Commenti nel Codice";
"aiprompts.prompt.commentsAudit.desc" = "Analizza i commenti esistenti, rileva quelli obsoleti/errati e fornisce suggerimenti per il miglioramento.";

"aiprompts.prompt.crashBugAudit.title" = "Analisi di Crash & Bug";
"aiprompts.prompt.crashBugAudit.desc" = "Analizza i log di crash e le segnalazioni di bug, trova la causa principale e suggerisce correzioni.";
"aiprompts.prompt.instrumentsGuide.title" = "Guida a Instruments & Profiling";
"aiprompts.prompt.instrumentsGuide.desc" = "Fornisce una guida alla profilazione con Xcode Instruments e offre raccomandazioni specifiche per il progetto.";

"aiprompts.prompt.networkAudit.title" = "Audit del Livello di Rete";
"aiprompts.prompt.networkAudit.desc" = "Verifica in modo completo il livello di rete, le chiamate API, la gestione degli errori e il flusso di dati.";
"aiprompts.prompt.apiMock.title" = "Mock API & Infrastruttura di Test";
"aiprompts.prompt.apiMock.desc" = "Crea l'infrastruttura di test API, la configurazione del server mock e la strategia di test di rete.";

"aiprompts.prompt.a11yAudit.title" = "Audit di Accessibilità";
"aiprompts.prompt.a11yAudit.desc" = "Verifica la conformità agli standard di accessibilità, rilevando problemi di VoiceOver, Dynamic Type e contrasto dei colori.";

"aiprompts.prompt.i18nAudit.title" = "Audit Completo della Localizzazione";
"aiprompts.prompt.i18nAudit.desc" = "Verifica in modo completo le stringhe hardcoded, le traduzioni mancanti, i formati data/numero e il supporto RTL.";

"aiprompts.prompt.gitWorkflow.title" = "Ottimizzazione del Workflow Git";
"aiprompts.prompt.gitWorkflow.desc" = "Verifica la cronologia Git, la strategia dei rami, la qualità dei commit e la configurazione di .gitignore.";
